# Telegram bot token from @BotFather
TELEGRAM_BOT_TOKEN=1234567890:replace_me

# Admin group/chat ID. For groups it usually starts with -100.
ADMIN_CHAT_ID=-1001234567890

# Temporary cashback feature flag. Keep disabled until cashback is re-enabled intentionally.
CASHBACK_ENABLED=false

# Public HTTPS URL of the Telegram Mini App. Leave empty to hide the Mini App button.
TMA_URL=https://example.com/slik-tma

# eSIM expiry reminder settings
ESIM_EXPIRY_REMINDER_DAYS_BEFORE=1
ESIM_EXPIRY_REMINDER_MAX_AGE_DAYS=60

# Optional notification routing
ORDERS_CHAT_ID=
CLIENT_ACTIVITY_CHAT_ID=
NEW_CLIENTS_CHAT_ID=
PAYMENTS_CHAT_ID=
TECH_ALERTS_CHAT_ID=

# USD/RUB card-payment rate settings
USD_RUB_FALLBACK_RATE=90
USD_RUB_MARKUP_PERCENT=0
