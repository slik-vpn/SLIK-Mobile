# Telegram bot token from @BotFather
TELEGRAM_BOT_TOKEN=1234567890:replace_me

# Admin group/chat ID. For groups it usually starts with -100.
ADMIN_CHAT_ID=-1001234567890

# Fallback USD/RUB rate for card payments when public rate sources are unavailable.
USD_RUB_FALLBACK_RATE=90

# Percent markup/buffer added to the fetched or fallback USD/RUB rate.
USD_RUB_MARKUP_PERCENT=3
