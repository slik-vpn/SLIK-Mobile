# Telegram bot token from @BotFather.
TELEGRAM_BOT_TOKEN=1234567890:replace_me

# Fallback/admin owner chat ID. Can be a private chat ID or a group ID.
ADMIN_CHAT_ID=-1001234567890

# Optional dedicated chats. Leave empty to fall back to ADMIN_CHAT_ID.
ORDERS_CHAT_ID=
ACTIVITY_CHAT_ID=
SYSTEM_CHAT_ID=
